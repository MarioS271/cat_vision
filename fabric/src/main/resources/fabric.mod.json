{
    "schemaVersion": 1,
    "id": "cat_vision",
    "version": "${version}",
    "name": "CatVision",
    "description": "${mod_description}",
    "authors": [
        "${mod_author}"
    ],
    "contact": {
        "homepage": "${mod_homepage_link}",
        "sources": "${mod_sources_link}",
        "issues": "${mod_issues_link}"
    },
    "license": "${mod_license}",
    "icon": "${mod_logo_file_path}",
    "environment": "client",
    "entrypoints": {
        "client": [
            "net.marios271.cat_vision.fabric.CatVisionFabricEntry"
        ],
        "modmenu": [
            "net.marios271.cat_vision.fabric.ModMenuIntegration"
        ]
    },
    "depends": {
        "fabricloader": ">=0.16.10",
        "minecraft": "~1.21.1",
        "java": ">=21",
        "fabric": "*"
    },
    "suggests": {
        "modmenu": "*"
    }
}
